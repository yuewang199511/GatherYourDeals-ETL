# Copy to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# -----------------------------------------------------------------------
# Step 1 — Azure Document Intelligence (OCR)
# -----------------------------------------------------------------------
# 1. Go to portal.azure.com → Create a resource → Document Intelligence
# 2. Choose the FREE tier (F0): 500 pages/month, no charge
# 3. After deployment: Keys and Endpoint → copy endpoint and Key 1
AZURE_DI_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
AZURE_DI_KEY=

# ADI cost is always logged at $0.0015/page (S0 rate) for accurate production cost tracking.

# -----------------------------------------------------------------------
# Step 2 — OpenRouter LLM (structuring)
# -----------------------------------------------------------------------
# 1. Sign up at https://openrouter.ai
# 2. Keys → Create key (free account, no credits needed for :free models)
OPENROUTER_API_KEY=sk-or-v1-...

# Default is the free-tier Gemini model — no credits needed.
# Upgrade to google/gemini-2.0-flash for higher rate limits.
ETL_MODEL=google/gemini-2.0-flash-exp:free

# -----------------------------------------------------------------------
# GYD data server (leave blank to run in extract-only mode)
# -----------------------------------------------------------------------
GYD_SERVER_URL=http://localhost:8080/api/v1
GYD_USERNAME=
GYD_PASSWORD=
