# Copy to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# -----------------------------------------------------------------------
# Step 1 — Azure Document Intelligence (OCR)
# -----------------------------------------------------------------------
# 1. Go to portal.azure.com → Create a resource → Document Intelligence
# 2. Choose the FREE tier (F0): 500 pages/month, no charge
# 3. After deployment: Keys and Endpoint → copy endpoint and Key 1
AZURE_DI_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
AZURE_DI_KEY=

# ADI cost is always logged at $0.0015/page (S0 rate) for accurate production cost tracking.

# -----------------------------------------------------------------------
# Step 2 — LLM provider (structuring + store name normalization)
# -----------------------------------------------------------------------
# Set to "openrouter" or "clod"
LLM_PROVIDER=openrouter

# Option A — OpenRouter
# 1. Sign up at https://openrouter.ai
# 2. Keys → Create key
OPENROUTER_API_KEY=sk-or-v1-...
OR_DEFAULT_MODEL=anthropic/claude-haiku-4.5

# Option B — CLOD
# 1. Sign up at https://app.clod.io
# 2. API Keys → Create key
# CLOD_API_KEY=
CLOD_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# -----------------------------------------------------------------------
# Step 3 — Azure Maps Geocoding (optional)
# -----------------------------------------------------------------------
# Leave blank to skip geocoding (lat/lon will be null in output)
# 1. In Azure Portal, add Azure Maps to your resource group
# 2. Choose Gen2 pricing tier (free: 5,000 requests/month)
# 3. Authentication → copy Primary Key
AZURE_MAPS_KEY=

# -----------------------------------------------------------------------
# GYD data service (leave blank to run in extract-only mode)
# -----------------------------------------------------------------------
GYD_SERVER_URL=http://localhost:8080/api/v1
GYD_USERNAME=
GYD_PASSWORD=
